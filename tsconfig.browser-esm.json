{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ES2020",
    "moduleResolution": "bundler",
    "lib": [
      "ES2021",
      "DOM"
    ],
    "strict": true,
    "noEmitOnError": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": false,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
    "noCheck": true
  },
  "include": [
    "public/app.ts",
    "public/spa/**/*.ts"
  ]
}
