{
  "name": "ds-ts",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-dependency TypeScript scaffold for a personalized travel system course project.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node dist/tests/index.js",
    "validate:data": "npm run build && node dist/scripts/validate-data.js",
    "benchmark": "npm run build && node dist/scripts/run-benchmarks.js",
    "start": "npm run build && node dist/src/server/index.js",
    "demo": "npm run build && node dist/scripts/demo.js"
  }
}
