{
  "name": "ds-ts",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript scaffold for a personalized travel system course project.",
  "type": "commonjs",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.20",
    "typescript": "^5.6.3"
  },
  "scripts": {
    "build:browser:esm": "tsc -p tsconfig.browser-esm.json",
    "build:browser:script": "tsc -p tsconfig.browser-script.json",
    "build:browser": "node scripts/browser-build.js",
    "build:server": "tsc -p tsconfig.json",
    "build": "npm run build:browser && npm run build:server",
    "test": "npm run build && node dist/tests/index.js",
    "validate:data": "npm run build && node dist/scripts/validate-data.js",
    "benchmark": "npm run build && node dist/scripts/run-benchmarks.js",
    "start": "npm run build && node dist/src/server/index.js",
    "demo": "npm run build && node dist/scripts/demo.js"
  }
}
